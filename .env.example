# Postgres (self-hosted, single container)
POSTGRES_DB=dubaicost
POSTGRES_USER=dubaicost
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg://dubaicost:changeme@db:5432/dubaicost

# Dubai Pulse / DLD Open Data (OAuth client_credentials) — free, requires registration
DUBAI_PULSE_CLIENT_ID=
DUBAI_PULSE_CLIENT_SECRET=
DUBAI_PULSE_TOKEN_URL=
DUBAI_PULSE_BASE_URL=

# Прямые ссылки на bulk CSV (Dubai Pulse open data, без OAuth).
# Проверить актуальность на страницах датасетов:
#   https://www.dubaipulse.gov.ae/data/dld-transactions/dld_transactions-open
#   https://www.dubaipulse.gov.ae/data/dld-registration/dld_rent_contracts-open
DLD_SALES_CSV_URL=https://www.dubaipulse.gov.ae/dataset/3b25a6f5-9077-49d7-8a1e-bc6d5dea88fd/resource/a37511b0-ea36-485d-bccd-2d6cb24507e7/download/transactions.csv
DLD_RENT_CSV_URL=https://www.dubaipulse.gov.ae/dataset/00768c45-f014-4cc6-937d-2b17dcab53fb/resource/765b5a69-ca16-4bfd-9852-74612f3c4ea6/download/rent_contracts.csv
SALES_SINCE_YEAR=2010

# Токен admin-эндпоинтов (очередь ручной валидации matching). Пусто = выключено.
ADMIN_TOKEN=

# Alert notifications on ETL failures / anomalies (pick one, optional)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_SMTP_URL=

# App
API_CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
